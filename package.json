{
  "name": "backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.927.0",
    "@aws-sdk/lib-storage": "^3.927.0",
    "@aws-sdk/s3-request-presigner": "^3.927.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "oracledb": "^6.10.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "ssh2": "^1.17.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src",
      "config"
    ],
    "ext": "js,cjs,json",
    "exec": "node server.js",
    "ignore": [
      "node_modules",
      "*.log"
    ]
  }
}
